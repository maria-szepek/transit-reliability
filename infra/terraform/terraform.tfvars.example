# Normal usage does not require terraform.tfvars.
#
# Use the root .env file:
#   WAREHOUSE_BACKEND=bigquery
#   GCP_PROJECT_ID=your-gcp-project-id
#
# Then run from the repository root:
#   make infra-plan
#   make infra-apply
#
# Only create terraform.tfvars if you intentionally want to bypass the Makefile.
